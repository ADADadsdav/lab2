DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=Movie
DB_HOST=postgres
DB_PORT=5432

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_67890
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# OAuth (Yandex)
YANDEX_CLIENT_ID=your_yandex_client_id_here
YANDEX_CLIENT_SECRET=your_yandex_client_secret_here
YANDEX_CALLBACK_URL=http://localhost:4200/auth/oauth/yandex/callback
