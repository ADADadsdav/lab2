# ================================
# Database Configuration
# ================================
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=Movie
DB_HOST=postgres
DB_PORT=5432

# ================================
# JWT Configuration
# ================================
# Секретный ключ для подписи Access Token (минимум 32 символа)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production_12345

# Секретный ключ для подписи Refresh Token (должен отличаться от ACCESS)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_67890

# Время жизни Access Token в секундах (15 минут)
JWT_ACCESS_EXPIRATION=900

# Время жизни Refresh Token в секундах (7 дней)
JWT_REFRESH_EXPIRATION=604800

# ================================
# OAuth Configuration (Yandex ID)
# ================================
YANDEX_CLIENT_ID=your_yandex_client_id_here
YANDEX_CLIENT_SECRET=your_yandex_client_secret_here

# Callback URL (должен совпадать с настройками приложения в Яндексе)
YANDEX_CALLBACK_URL=http://localhost:4200/auth/oauth/yandex/callback
